# Example environment for "By Petition".
#
# To run Django on the host (uv run manage.py ...), copy this to .env;
# settings.py loads it via django-environ. The docker compose stack sets its
# own values, so .env is optional when using `docker compose up`.
# Never commit a real .env.

# --- Django ---
DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:8000

# --- Database (SQLite) ---
# Host-run Django defaults to ./db.sqlite3 (this value). The Docker image
# already sets SQLITE_PATH=/data/db.sqlite3, so in containers you only need to
# mount a volume at /data — no need to set this. Override only for a custom path.
SQLITE_PATH=db.sqlite3
