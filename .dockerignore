# VCS / tooling
.git
.gitignore
.claude
.DS_Store

# Local Python env / caches (never ship a host-built, glibc venv)
.venv
**/__pycache__
*.pyc
*.egg-info

# Local SQLite DB (legacy) + env secrets + locally-collected static
db.sqlite3
.env
staticfiles/

